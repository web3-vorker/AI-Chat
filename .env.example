# =============================================
# AI Chat - пример переменных окружения
# =============================================
# Скопируйте этот файл как .env и заполните значения

# ====== OpenRouter ======
# Получить ключ: https://openrouter.ai/
OPENROUTER_API_KEY=sk-or-v1-YOUR_API_KEY_HERE

# Модель (можно менять без правок кода)
OPENROUTER_MODEL=google/gemma-4-31b-it:free

# (Опционально) метаданные для OpenRouter
OPENROUTER_SITE_URL=http://127.0.0.1:8000
OPENROUTER_APP_NAME=AI Chat

# ====== Безопасность ======
# Для продакшена используйте сильный случайный ключ
SECRET_KEY=your-secret-key-change-in-production

# Cookies
# В проде под HTTPS: COOKIE_SECURE=true
COOKIE_SECURE=false
# SameSite: strict | lax | none
# Если вы запускаете фронт отдельно на http://127.0.0.1:5500, лучше поставить lax.
COOKIE_SAMESITE=strict

# ====== CORS ======
# Если вы открываете UI с бэка (http://127.0.0.1:8000/), CORS обычно не нужен.
# Если запускаете отдельный фронт (5500/3000), добавьте origin сюда.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:5500,http://localhost:5500

# ====== DB ======
# DATABASE_URL=sqlite+aiosqlite:///chat_history.db

# ====== AI контекст ======
MAX_MESSAGES_IN_CONTEXT=20
MAX_CHAT_TITLE_LENGTH=100
